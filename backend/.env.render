# Application Settings
APP_ENV=development
DEBUG=true

# Database
MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=gim

# API Keys (get these from respective services)
NEWS_API_KEY=
YOUTUBE_API_KEY=
OPENAI_API_KEY=
ACLED_API_KEY=
ACLED_EMAIL=

# News Configuration
NEWS_PROVIDER=gdelt
NEWS_SOURCES=
NEWS_INGEST_LIMIT=40
RSS_FEEDS=https://feeds.reuters.com/reuters/worldNews,https://rss.nytimes.com/services/xml/rss/nyt/World.xml,https://feeds.bbci.co.uk/news/world/rss.xml

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=15

# Stock Configuration
STOCK_SYMBOLS=DEFAULT
STOCK_HISTORY_PERIOD=6mo
STOCK_MIN_POINTS=55
STOCK_MAX_SYMBOLS=30
MODEL_AUTO_TRAIN_ON_REFRESH=false
MODEL_TRAIN_RETRY_MINUTES=60

# Features
USE_TRANSFORMER_SENTIMENT=false
RL_ENABLED=true
RL_POLICY_NAME=market_q_policy_v1
USE_TRANSFORMER_EVENT_CLASSIFIER=false
USE_OPENAI_EVENT_CLASSIFIER=false
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

# Ground Truth
GROUND_TRUTH_ENABLED=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Request Timeouts (in seconds)
REQUEST_TIMEOUT=20
EXTERNAL_API_TIMEOUT=30
